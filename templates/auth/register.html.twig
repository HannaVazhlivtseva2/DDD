{% extends 'auth/_layout.html.twig' %}

{% block title %}Register{% endblock %}

{% block auth_body %}
    <h1 class="h4 mb-3">Create an account</h1>

    {{ form_start(form) }}
        <div class="row">
            <div class="col-6">{{ form_row(form.firstName) }}</div>
            <div class="col-6">{{ form_row(form.lastName) }}</div>
        </div>
        {{ form_row(form.email) }}
        {{ form_row(form.phone) }}
        {{ form_row(form.gender) }}
        {{ form_row(form.plainPassword, {help: 'At least 8 characters, with an uppercase letter, a lowercase letter, a digit, and a symbol.'}) }}
        {{ form_row(form.plainPasswordRepeat) }}
        <button type="submit" class="btn btn-primary w-100">Register</button>
    {{ form_end(form) }}

    <p class="mt-3 mb-0 text-center">
        Already have an account? <a href="{{ path('app_login') }}">Log in</a>
    </p>
{% endblock %}
