{% extends 'auth/_layout.html.twig' %}

{% block title %}Reset password{% endblock %}

{% block auth_body %}
    <h1 class="h4 mb-3">Reset password</h1>

    {% if not valid %}
        <div class="alert alert-danger">This password reset link is invalid or has expired.</div>
        <p class="mt-3 mb-0 text-center">
            <a href="{{ path('app_forgot_password') }}">Request a new link</a>
        </p>
    {% else %}
        <p class="text-secondary">Choose a new password for <strong>{{ email }}</strong>.</p>

        {{ form_start(form) }}
            {{ form_row(form.plainPassword, {help: 'At least 8 characters, with an uppercase letter, a lowercase letter, a digit, and a symbol.'}) }}
            {{ form_row(form.plainPasswordRepeat) }}
            <button type="submit" class="btn btn-primary w-100">Reset password</button>
        {{ form_end(form) }}
    {% endif %}
{% endblock %}
