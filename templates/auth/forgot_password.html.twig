{% extends 'auth/_layout.html.twig' %}

{% block title %}Forgot password{% endblock %}

{% block auth_body %}
    <h1 class="h4 mb-3">Forgot your password?</h1>
    <p class="text-secondary">Enter your email and we'll send you a link to reset it.</p>

    {{ form_start(form) }}
        {{ form_row(form.email) }}
        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
    {{ form_end(form) }}

    <p class="mt-3 mb-0 text-center">
        <a href="{{ path('app_login') }}">Back to login</a>
    </p>
{% endblock %}
