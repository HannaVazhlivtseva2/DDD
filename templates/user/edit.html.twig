{% extends 'base.html.twig' %}

{% block title %}Profile Edit{% endblock %}

{% block nav %}
    {% include 'layout/header.html.twig' %}
{% endblock %}

{% block body %}
    <h1 class="h4 mb-3">Profile edit</h1>

    <div class="d-flex align-items-center gap-3 mb-4">
        {% if avatarUrl %}
            <img src="{{ avatarUrl }}?v={{ random() }}" alt="Avatar" class="rounded-circle" width="80" height="80" style="object-fit: cover;">
        {% else %}
            <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                <span class="text-secondary">No photo</span>
            </div>
        {% endif %}

        {{ form_start(avatarForm, {action: path('edit_user_avatar'), method: 'POST', attr: {class: 'd-flex align-items-center gap-2'}}) }}
            {{ form_widget(avatarForm.avatarFile) }}
            <button type="submit" class="btn btn-outline-primary btn-sm">Upload</button>
        {{ form_end(avatarForm) }}
    </div>

    {{ form_start(form) }}
    <div class="row">
        <div class="col-6">{{ form_row(form.firstName) }}</div>
        <div class="col-6">{{ form_row(form.lastName) }}</div>
    </div>
    {{ form_row(form.phone) }}
    {{ form_row(form.gender) }}
    <button type="submit" class="btn btn-primary w-100">Update</button>
    {{ form_end(form) }}
{% endblock %}
